<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.min.mes.mapper.user.UserMapper">

    <select id="findByUserId" parameterType="String" resultType="com.min.mes.dto.user.UserVO">
        SELECT
        USER_ID   AS id,
        USER_NM   AS name,
        USE_YN    AS useYn
        FROM TB_USER
        WHERE USER_ID = #{userId}
        AND USE_YN = 'Y'
    </select>

    <select id="selectUser" parameterType="String" resultType="java.util.HashMap">
        SELECT * FROM TB_USER WHERE USER_ID = #{userId}
    </select>


</mapper>





